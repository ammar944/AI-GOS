# Feature flags
NEXT_PUBLIC_ENABLE_PARALLEL_SECTIONS=true
AI_SDK_DEVTOOLS=false

# Lab engine model selection
# Local live-proof runs should set this explicitly; production may keep the
# code default when Anthropic auth is intentionally configured.
LAB_ENGINE_PROVIDER=deepseek-direct
DEEPSEEK_API_KEY=

# Access bootstrap
APP_BOOTSTRAP_INTERNAL_EMAILS=
