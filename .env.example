# Feature flags
NEXT_PUBLIC_ENABLE_PARALLEL_SECTIONS=true
AI_SDK_DEVTOOLS=false

# Lab engine model selection
# Local live-proof runs should set this explicitly; production may keep the
# code default when Anthropic auth is intentionally configured.
LAB_ENGINE_PROVIDER=deepseek-direct
DEEPSEEK_API_KEY=

# Access bootstrap
APP_BOOTSTRAP_INTERNAL_EMAILS=

# GLM (agentic section writer) — dev routes via Ollama Cloud proxy, prod via z.ai/BigModel
GLM_BASE_URL=http://localhost:11434/v1   # dev Ollama proxy; prod: https://open.bigmodel.cn/api/paas/v4
GLM_MODEL_ID=glm-5.2:cloud               # prod: the z.ai model id
GLM_API_KEY=ollama                       # dev Ollama proxy ignores; prod: real z.ai key
# Per-section agentic-GLM canary (csv of sectionIds). Empty = off (default = current path).
LAB_AGENTIC_GLM_SECTIONS=
