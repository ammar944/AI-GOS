{
  "name": "research-competitor",
  "version": "1.0.0",
  "description": "Section 03 — Competitor Landscape & Positioning. Agent collects, TypeScript validates, HTML renders.",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "validate": "tsx scripts/validate.ts",
    "report": "tsx scripts/generate-report.ts",
    "fetch-ads": "tsx scripts/fetch-ads.ts",
    "merge-ads": "tsx scripts/merge-ads.ts",
    "merge-fragments": "tsx scripts/merge-fragments.ts",
    "merge-sov": "tsx scripts/merge-sov.ts",
    "sanity-check": "tsx scripts/sanity-check.ts",
    "orchestrate": "tsx scripts/orchestrate.ts",
    "screenshot": "tsx scripts/screenshot.ts",
    "cache:stats": "tsx scripts/cache.ts stats",
    "cache:clear": "tsx scripts/cache.ts clear",
    "test": "npm run check && npm run validate"
  },
  "dependencies": {
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "playwright": "^1.49.0"
  }
}
