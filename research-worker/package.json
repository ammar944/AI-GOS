{
  "name": "aigos-research-worker",
  "version": "1.0.0",
  "description": "Background research worker for AIGOS corpus and extraction jobs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "vitest run",
    "test:run": "vitest run",
    "eval:snapshot": "ts-node-dev --transpile-only evals/snapshot.ts",
    "eval:research": "ts-node-dev --transpile-only evals/run-eval.ts",
    "eval:baseline": "ts-node-dev --transpile-only evals/baseline-run.ts",
    "eval:corpus-minimums": "ts-node-dev --transpile-only evals/corpus-minimums.ts",
    "eval:live-sonar-corpus": "ts-node-dev --transpile-only evals/live-sonar-corpus.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/perplexity": "^3.0.23",
    "@anthropic-ai/sdk": "^0.78.0",
    "@antv/mcp-server-chart": "*",
    "@mendable/firecrawl-js": "^4.12.0",
    "@supabase/supabase-js": "^2.87.1",
    "ai": "^6.0.116",
    "apify-client": "^2.22.2",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
