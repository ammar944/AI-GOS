# Railway Research Worker — Local Dev
PORT=3001
ANTHROPIC_API_KEY=your_anthropic_key
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
RAILWAY_API_KEY=dev-secret
FIRECRAWL_API_KEY=optional_firecrawl_key
SPYFU_API_KEY=optional_spyfu_key

# Optional Anthropic Platform Skills for the deep research program only.
# Comma-separated tokens. Defaults to custom skills; optionally prefix with
# custom: or anthropic: and suffix with @version (omit version for latest).
# Example: RESEARCH_DEEP_PROGRAM_SKILL_IDS=custom:skill_abc123,anthropic:built_in_skill@latest
# If left empty, worker defaults to the eight new AI-GOS GTM Platform Skills uploaded 2026-05-06:
# market/category, buyer/ICP, competitive positioning, VOC/objections, demand/intent,
# offer diagnostic, GTM synthesis, and activation plan.
# Override only when testing alternate skills or pinned versions.
RESEARCH_DEEP_PROGRAM_SKILL_IDS=
# Optional shared skills list merged before the deep-program-specific list.
ANTHROPIC_PLATFORM_SKILL_IDS=
