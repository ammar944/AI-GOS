{
  "meta": {
    "primaryText": { "optimal": 125, "max": 125, "label": "Primary text (visible before 'See more')" },
    "headline": { "optimal": 40, "max": 40, "label": "Headline" },
    "description": { "optimal": 30, "max": 30, "label": "Description (below headline)" },
    "videoHook": { "seconds": 3, "label": "Hook window (stop scrolling)" },
    "videoDuration": { "short": 30, "long": 60, "max": 60, "label": "Feed video duration" },
    "storyDuration": { "max": 60, "label": "Story/Reel duration" },
    "carouselCards": { "min": 2, "max": 10 },
    "carouselHeadline": { "max": 40 },
    "carouselDescription": { "max": 20 },
    "imageTextOverlay": { "maxPercent": 20, "note": "Meta reduces reach with >20% text overlay" },
    "safeZone": { "top": 14, "bottom": 20, "note": "Top 14% and bottom 20% covered by UI" }
  },
  "google": {
    "rsaHeadline": { "max": 30, "count": 15, "label": "RSA headline (up to 15)" },
    "rsaDescription": { "max": 90, "count": 4, "label": "RSA description (up to 4)" },
    "displayShortHeadline": { "max": 30, "count": 5 },
    "displayLongHeadline": { "max": 90, "count": 5 },
    "displayDescription": { "max": 90, "count": 5 },
    "shoppingTitle": { "max": 150, "visible": 70 },
    "shoppingDescription": { "max": 5000, "visible": 180 },
    "note": "RSA headlines/descriptions must work independently. Any combination must make sense. Pin only when legally required."
  },
  "linkedin": {
    "introText": { "optimal": 150, "max": 600, "label": "Introductory text" },
    "headline": { "optimal": 70, "max": 200, "label": "Headline" },
    "description": { "optimal": 100, "max": 100, "label": "Description (truncated in feed)" },
    "carouselHeadline": { "max": 45 },
    "inMailSubject": { "max": 60 },
    "inMailBody": { "max": 1500, "recommended": 500 },
    "inMailCta": { "max": 20 },
    "textAdHeadline": { "max": 25 },
    "textAdDescription": { "max": 75 },
    "videoDuration": { "recommended": "15-30s", "max": "30min" },
    "captionNote": "85% watch muted. SRT captions highly recommended."
  },
  "tiktok": {
    "adText": { "max": 100, "label": "Ad text overlay" },
    "videoDuration": { "optimal": "15-30s", "max": 60 },
    "safeZone": { "top": 15, "bottom": 20, "note": "Keep branding in center 65% vertically" }
  },
  "email": {
    "subjectLine": { "max": 50, "note": "No clickbait. No ALL CAPS. Curiosity or specificity, never both." },
    "previewText": { "max": 90, "note": "Extends subject, never repeats it." },
    "cta": { "note": "Single, clear, benefit-forward. One link only." }
  }
}
